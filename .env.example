# dev-only image key, never deploy
WILLOW_IMAGE_API_KEY=

# optional comma-separated mullvad wireguard relay names for image generation
WILLOW_IMAGE_MULLVAD_EXITS=

# supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service key from dashboard -> project settings -> api keys, backend only
SUPABASE_SERVICE_ROLE_KEY=

# public url of the site, swap when a custom domain appears
NEXT_PUBLIC_SITE_URL=http://localhost:3000
