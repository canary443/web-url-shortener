# dev-only image key, never deploy
WILLOW_IMAGE_API_KEY=

# optional comma-separated mullvad wireguard relay names for image generation
WILLOW_IMAGE_MULLVAD_EXITS=

# optional rotating proxy for image generation, replaces the mullvad requirement
WILLOW_IMAGE_PROXY=

# supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service key from dashboard -> project settings -> api keys, backend only
SUPABASE_SERVICE_ROLE_KEY=

# public url of the site, swap when a custom domain appears
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# personal access token from supabase.com/dashboard/account/tokens,
# lets the supabase mcp apply migrations. local only
SUPABASE_ACCESS_TOKEN=

# admin panel access, comma separated account emails
ADMIN_EMAILS=

# cloudflare turnstile captcha. empty disables the captcha everywhere.
# dev test keys: sitekey 1x00000000000000000000AA,
# secret 1x0000000000000000000000000000000AA (always pass)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# optional smtp for admin suspension emails (any provider, e.g. resend/brevo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# where replies to notification emails should land (the sender box is fake)
SMTP_REPLY_TO=
